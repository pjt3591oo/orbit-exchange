NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbit?schema=public
REDIS_URL=redis://localhost:6379

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=orbit-workers

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
AUDIT_S3_BUCKET=orbit-audit-logs
USER_EVENTS_SNS_TOPIC_ARN=arn:aws:sns:ap-northeast-2:000000000000:orbit-user-events

# comma list: candle,fanout,notification,audit
WORKERS=candle,fanout,notification,audit
