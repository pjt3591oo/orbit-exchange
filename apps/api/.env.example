NODE_ENV=development
PORT=3000
API_CORS_ORIGIN=http://localhost:5173

# Postgres
DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbit?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=orbit-api

# AWS (LocalStack in dev)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
AUDIT_S3_BUCKET=orbit-audit-logs
USER_EVENTS_SNS_TOPIC_ARN=arn:aws:sns:ap-northeast-2:000000000000:orbit-user-events

# JWT (프로덕션에선 Secrets Manager에서 로드)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d
