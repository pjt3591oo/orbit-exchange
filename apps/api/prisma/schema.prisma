generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSide {
  BID
  ASK
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
  REJECTED
}

enum CandleInterval {
  M1
  M5
  M15
  H1
  H4
  D1
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // Set true by an admin (WALLET_ADJUST role) to block this user from
  // submitting new orders. Existing OPEN/PARTIAL orders are NOT auto-cancelled
  // — admin must force-cancel them separately if desired. Checked at the top
  // of OrderService.submit.
  frozen       Boolean  @default(false)
  createdAt    DateTime @default(now())
  wallets      Wallet[]
  orders       Order[]
}

/// Append-only audit trail for every admin mutation. Written by
/// AdminAuditInterceptor (via the @AdminAction decorator) so the controller
/// body stays clean. The `before`/`after` columns capture the row state
/// for diffability.
model AdminAuditLog {
  id         BigInt   @id @default(autoincrement())
  adminId    String   // Keycloak `sub` (UUID)
  adminEmail String   // For human-readable searches
  action     String   // e.g. "user.freeze" / "wallet.adjust" / "market.update"
  targetType String   // e.g. "User" / "Wallet" / "Order" / "Market" / "Asset"
  targetId   String
  before     Json?
  after      Json?
  reason     String?  // Required by reasonRequired:true actions
  ip         String?
  ua         String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}

model Asset {
  symbol   String   @id
  name     String
  decimals Int
  wallets  Wallet[]
}

model Wallet {
  id       String  @id @default(cuid())
  userId   String
  asset    String
  /// MUST stay >= 0 — enforced by Postgres CHECK constraint (see migration
  /// 20260427120000_wallet_non_negative). Defense in depth: even if some
  /// new mutation forgets the conditional UPDATE pattern, the DB rejects.
  balance  Decimal @default(0) @db.Decimal(28, 12)
  /// MUST stay >= 0 — same CHECK constraint protection.
  locked   Decimal @default(0) @db.Decimal(28, 12)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetRef Asset   @relation(fields: [asset], references: [symbol])

  @@unique([userId, asset])
  @@index([userId])
}

model Market {
  symbol      String  @id
  baseAsset   String
  quoteAsset  String
  tickSize    Decimal @db.Decimal(28, 12)
  stepSize    Decimal @db.Decimal(28, 12)
  minNotional Decimal @db.Decimal(28, 12)
  takerFeeBp  Int     @default(20)
  makerFeeBp  Int     @default(10)
  enabled     Boolean @default(true)
  orders      Order[]
  trades      Trade[]
  candles     Candle[]
}

model Order {
  id        BigInt      @id @default(autoincrement())
  userId    String
  market    String
  side      OrderSide
  type      OrderType
  price     Decimal?    @db.Decimal(28, 12)
  quantity  Decimal     @db.Decimal(28, 12)
  leaveQty  Decimal     @db.Decimal(28, 12)
  filledQty Decimal     @default(0) @db.Decimal(28, 12)
  status    OrderStatus @default(OPEN)
  /// UUID v4 generated by API at submission time. Used by the matcher to
  /// detect duplicate command delivery from Kafka (see ADR-0003). Nullable
  /// for backward compatibility with rows created before this field existed.
  commandId String?     @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketRef Market      @relation(fields: [market], references: [symbol])

  @@index([userId, createdAt])
  @@index([market, status, price])
}

model Trade {
  id           BigInt    @id @default(autoincrement())
  sequence     BigInt
  market       String
  price        Decimal   @db.Decimal(28, 12)
  quantity     Decimal   @db.Decimal(28, 12)
  makerOrderId BigInt
  takerOrderId BigInt
  makerSide    OrderSide
  takerSide    OrderSide
  makerUserId  String
  takerUserId  String
  makerFee     Decimal   @db.Decimal(28, 12)
  takerFee     Decimal   @db.Decimal(28, 12)
  /// Deterministic per-match identifier shaped as `<commandId>#<idx>`. The
  /// settler derives this from the originating SUBMIT command's commandId
  /// plus the trade index within that command. Re-running the same command
  /// would re-derive the same matchId, so the unique constraint catches
  /// double-settlement at DB level (defense in depth — ADR-0003 §D5).
  matchId      String?   @unique
  createdAt    DateTime  @default(now())
  marketRef    Market    @relation(fields: [market], references: [symbol])

  @@index([market, createdAt])
  @@index([makerOrderId])
  @@index([takerOrderId])
}

/// Transactional outbox — used by both api (SUBMIT/CANCEL commands) and
/// matcher (TRADE / ORDER / ORDERBOOK / USER_EVENT events) to make Kafka
/// publishes survive a crash between DB commit and broker ack.
///
/// Producers INSERT a row inside the same prisma.$transaction() that mutates
/// Order/Trade/Wallet. The outbox-relay worker polls processedAt IS NULL
/// rows in createdAt order and publishes them. processedAt is set only on
/// successful broker ack — relay failure causes retry on the next poll.
///
/// At-least-once: relay may publish the same row twice if it dies between
/// kafka.send and the UPDATE. Consumers MUST be idempotent (see ADR-0003).
model OutboxEvent {
  id          BigInt    @id @default(autoincrement())
  /// Kafka topic the relay should publish to.
  topic       String
  /// Partition key (e.g. market symbol for orderbook/order events, userId
  /// for user-events, orderId for command topics).
  key         String
  /// Original event payload — relay JSON.stringify's this back out.
  payload     Json
  /// Optional headers (carries traceparent so producer→consumer trace links
  /// survive the outbox detour).
  headers     Json?

  createdAt   DateTime  @default(now())
  /// NULL → not yet published. Set to NOW() on successful broker ack.
  processedAt DateTime?
  attempts    Int       @default(0)
  lastError   String?

  /// Relay polling — scan unprocessed rows in createdAt order.
  @@index([processedAt, createdAt])
  /// Operational queries (per-topic age / count).
  @@index([topic, createdAt])
}

/// HTTP-side request idempotency. The IdempotencyInterceptor checks the
/// `Idempotency-Key` header (UUID v4) on mutating endpoints; first request
/// runs the handler and caches the response, subsequent requests with the
/// same key return the cached response. Body hash mismatches return 409.
///
/// Scope = (userId, key, method, path) so different endpoints can reuse the
/// same client-side key without cross-talk. expiresAt is set to createdAt+24h
/// and a cron job deletes expired rows.
model IdempotencyKey {
  id             BigInt   @id @default(autoincrement())
  userId         String
  key            String
  method         String
  path           String
  /// sha256 of canonicalised request body. Mismatch on cache hit → 409.
  requestHash    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@unique([userId, key, method, path])
  @@index([expiresAt])
}

/// DLQ ledger — the dlq-monitor worker mirrors every message landing on
/// `orbit.dlq.v1` into this table so admins have a queryable surface
/// (admin SPA `/dlq` page) for replay / dismiss workflows. ADR-0004 §D6.
///
/// `payload` is the original message bytes. `headers` carries the
/// withRetryPolicy provenance (x-orbit-original-*, x-orbit-attempt,
/// x-orbit-last-error, x-orbit-worker).
///
/// resolvedAt + resolution + resolvedBy are filled by the admin action.
/// Rows are append-only otherwise; failed replays produce a NEW DlqEvent
/// row when they fail again (not an UPDATE on this one).
model DlqEvent {
  id                BigInt    @id @default(autoincrement())
  originalTopic     String
  originalPartition Int
  originalOffset    String
  payload           Bytes
  headers           Json
  worker            String
  lastError         String
  attempt           Int
  enqueuedAt        DateTime  @default(now())

  resolvedAt        DateTime?
  /// 'replayed' | 'dismissed' — set with resolvedAt by the admin UI.
  resolution        String?
  /// Keycloak `sub` of the admin who acted, mirroring AdminAuditLog.
  resolvedBy        String?

  /// Lineage — if THIS row was created because a previous DlqEvent was
  /// replayed by an admin and the replayed message ended up failing again,
  /// `replayedFromId` points at that previous row's id. NULL for the
  /// first DLQ row of a freshly failed message.
  ///
  /// Used to distinguish "replay 성공" (no descendant) from "replay 후
  /// 재실패" (descendant exists) in the admin UI without needing a
  /// separate resolution status. The admin-dlq replay() handler adds
  /// `x-orbit-replay-of: <id>` to the republished message; dlq-monitor
  /// reads that header on insert.
  replayedFromId    BigInt?

  @@index([resolvedAt, enqueuedAt])
  @@index([originalTopic, enqueuedAt])
  @@index([worker, enqueuedAt])
  /// Cheap lookup "does any DlqEvent point at me?" used by the admin
  /// list query to compute the replay-chain status badge.
  @@index([replayedFromId])
}

model Candle {
  id        BigInt         @id @default(autoincrement())
  market    String
  interval  CandleInterval
  openTime  DateTime
  open      Decimal        @db.Decimal(28, 12)
  high      Decimal        @db.Decimal(28, 12)
  low       Decimal        @db.Decimal(28, 12)
  close     Decimal        @db.Decimal(28, 12)
  volume    Decimal        @db.Decimal(28, 12)
  marketRef Market         @relation(fields: [market], references: [symbol])

  @@unique([market, interval, openTime])
  @@index([market, interval, openTime])
}
