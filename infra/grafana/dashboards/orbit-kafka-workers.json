          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (topic) (rate(orbit_kafka_publish_duration_ms_count{result=\"error\"}[1m]))",
          "legendFormat": "{{topic}}"
        }
      ],
      "title": "Kafka publish errors /s",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
