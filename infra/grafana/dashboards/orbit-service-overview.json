{
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Process health",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(process_cpu_seconds_total{service=~\"orbit-.*\"}[1m])",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "CPU (per service)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nodejs_heap_size_used_bytes{service=~\"orbit-.*\"} / 1024 / 1024",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "Heap used (MB)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 4,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nodejs_eventloop_lag_p99_seconds{service=~\"orbit-.*\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "Event loop lag — p99",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 10,
      "title": "HTTP (api)",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "id": 11,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(orbit_orders_submitted_total[1m]))",
          "legendFormat": "rate"
        }
      ],
      "title": "Orders submitted /s",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 10
      },
      "id": 12,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(rate(orbit_orders_submitted_total{result=~\"4xx|5xx\"}[5m])) or vector(0)) / clamp_min(sum(rate(orbit_orders_submitted_total[5m])), 1)"
        }
      ],
      "title": "Submit error % (last 5m)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 13,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(orbit_order_submit_duration_ms_bucket[1m])))",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orbit_order_submit_duration_ms_bucket[1m])))",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(orbit_order_submit_duration_ms_bucket[1m])))",
          "legendFormat": "p99"
        }
      ],
      "title": "Order submit latency (ms)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "id": 14,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(orbit_realtime_active_connections)"
        }
      ],
      "title": "WS connections",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 16
      },
      "id": 15,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (kind) (rate(orbit_realtime_room_emit_total[1m]))",
          "legendFormat": "{{kind}}"
        }
      ],
      "title": "Realtime room emits /s (by kind)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "orbit",
    "overview"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values(orbit_orders_submitted_total, service)",
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ORBIT — Service Overview",
  "uid": "orbit-overview"
}
