{
  "panels": [
    {
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le, symbol) (rate(orbit_matcher_settle_duration_ms_bucket{symbol=~\"$symbol\"}[1m])))",
          "legendFormat": "{{symbol}} p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, symbol) (rate(orbit_matcher_settle_duration_ms_bucket{symbol=~\"$symbol\"}[1m])))",
          "legendFormat": "{{symbol}} p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le, symbol) (rate(orbit_matcher_settle_duration_ms_bucket{symbol=~\"$symbol\"}[1m])))",
          "legendFormat": "{{symbol}} p99"
        }
      ],
      "title": "Settle duration p50/p95/p99 (ms)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "orbit_matcher_queue_depth{symbol=~\"$symbol\"}",
          "legendFormat": "{{symbol}}"
        }
      ],
      "title": "Per-market p-queue depth",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "orbit_orderbook_depth_levels{market=~\"$symbol\"}",
          "legendFormat": "{{market}} / {{side}}"
        }
      ],
      "title": "Orderbook depth (level count per side)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (cmdType, result) (rate(orbit_order_commands_consumed_total[1m]))",
          "legendFormat": "{{cmdType}} / {{result}}"
        }
      ],
      "title": "Commands consumed by type & result",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(orbit_order_commands_consumed_total{result=\"error\"}[5m]))"
        }
      ],
      "title": "Settle errors (5m)",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(orbit_trades_executed_total[15m]))"
        }
      ],
      "title": "Trades / 15m",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(orbit_order_commands_consumed_total{result=\"noop\"}[5m]))"
        }
      ],
      "title": "No-op commands (5m)",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "orbit",
    "matcher"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "includeAll": true,
        "multi": true,
        "name": "symbol",
        "query": "label_values(orbit_matcher_settle_duration_ms_count, symbol)",
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ORBIT — Matcher Internals",
  "uid": "orbit-matcher"
}
